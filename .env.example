# Copy to .env.local at the repo root and fill in the values.
# (.env.local is gitignored.)

# Supabase project — Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Google AI Studio API key for the worker's lead-dancer detector
# (spec.md round-5 §Fix 5). Without this, the worker falls through to
# a geometric heuristic — lead detection still works on
# single-camera-depth multi-person clips but the picker UI loses the
# "✨ our guess" explanation.
GEMINI_API_KEY=
