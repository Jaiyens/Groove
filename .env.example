# Copy to .env.local at the repo root and fill in the values.
# (.env.local is gitignored.)

# Supabase project — Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Google AI Studio API key. Used by:
# - worker's lead-dancer detector (spec.md round-5 §Fix 5) — without
#   this, the worker falls through to a geometric heuristic; lead
#   detection still works on single-camera-depth multi-person clips
#   but the picker UI loses the "✨ our guess" explanation.
# - the Mode B post-attempt Gemini 2.5 Flash grader (SPECK Hybrid
#   scoring §gemini/route.ts). Without this, /api/score-gemini returns
#   500 and the results screen silently falls back to MediaPipe scoring.
GEMINI_API_KEY=

# Mode B validation flag. When 'true', the post-attempt results screen
# shows Gemini's score as the headline and surfaces the MediaPipe score
# as a small grey debug pill below ("MediaPipe (debug): NN") with a
# "Why are these different?" expander. Flip to 'false' once 10-20 real
# attempts confirm Gemini is the better signal.
NEXT_PUBLIC_SHOW_BOTH_SCORES=true
